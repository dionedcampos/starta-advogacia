---
import Logo from './Logo.astro';

const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-grid">
    <div class="footer-info">
      <Logo width="160" height="45" light={true} />
      <p class="footer-desc">Defesa estratégica e excelência jurídica em todo o território nacional. Compromisso inabalável com a ética e os resultados.</p>
      <div class="social-links">
        <a href="https://www.instagram.com/ghadvocacia_/" target="_blank" aria-label="Instagram"><i class="fa-brands fa-instagram" aria-hidden="true"></i></a>
        <a href="https://wa.me/559991764210" target="_blank" aria-label="WhatsApp"><i class="fa-brands fa-whatsapp" aria-hidden="true"></i></a>
        <a href="https://www.linkedin.com/company/ghadvocacia" target="_blank" aria-label="LinkedIn"><i class="fa-brands fa-linkedin-in" aria-hidden="true"></i></a>
      </div>
    </div>
    
    <div class="footer-links">
      <h3>Links Rápidos</h3>
      <ul>
        <li><a href="#home">Início</a></li>
        <li><a href="#about">Sobre o Escritório</a></li>
        <li><a href="#services">Áreas de Atuação</a></li>
        <li><a href="#testimonials">O que dizem</a></li>
      </ul>
    </div>
    
    <div class="footer-contact">
      <h3>Contato</h3>
      <address>
        <p>R. 15 de Novembro, 601 - Centro<br/>João Lisboa - MA, 65922-000</p>
        <p><a href="mailto:contato@ghadvocacia.com.br">contato@ghadvocacia.com.br</a></p>
        <p><a href="tel:+5599991764210">(99) 99176-4210</a></p>
      </address>
    </div>
  </div>
  
  <div class="footer-bottom">
    <div class="container">
      <p>&copy; {currentYear} GH Advocacia. Todos os direitos reservados. <span>Excelência em cada detalhe.</span></p>
      <p class="credits">Desenvolvido por <a href="https://startaweb.com.br" target="_blank">Agência StartaWeb</a></p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--bg-dark); /* Preto Profundo */
    color: var(--text-light);
    padding: 6rem 0 0;
    border-top: 4px solid var(--primary); /* Gold header for the footer */
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 5rem;
    padding-bottom: 5rem;
  }

  .footer-desc {
    margin: 2rem 0;
    color: var(--text-muted-light);
    max-width: 380px;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .social-links {
    display: flex;
    gap: 1.2rem;
  }

  .social-links a {
    width: 44px;
    height: 44px;
    background-color: rgba(74, 71, 65, 0.1);
    border: 1px solid rgba(74, 71, 65, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0;
    font-size: 1.1rem;
    color: var(--primary);
    transition: var(--transition);
  }

  .social-links a:hover {
    background-color: var(--primary);
    color: var(--bg-dark);
    transform: translateY(-5px);
  }

  .footer-links h3, .footer-contact h3 {
    margin-bottom: 2rem;
    font-size: 1.4rem;
    color: var(--primary);
    font-family: var(--font-serif);
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .footer-links ul {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-links a {
    color: var(--text-muted-light);
    font-weight: 500;
    transition: var(--transition);
  }

  .footer-links a:hover {
    color: var(--primary);
    padding-left: 10px;
  }

  .footer-contact address {
    font-style: normal;
  }

  .footer-contact p {
    margin-bottom: 1.2rem;
    color: var(--text-muted-light);
    font-size: 1.05rem;
  }

  .footer-contact a {
    color: inherit;
    transition: var(--transition);
  }

  .footer-contact a:hover {
    color: var(--primary);
  }

  .footer-bottom {
    background-color: rgba(0, 0, 0, 0.2);
    padding: 2.5rem 0;
    text-align: center;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.3);
  }

  .footer-bottom span {
    display: block;
    margin-top: 0.5rem;
    color: var(--primary);
    font-weight: 600;
  }

  .credits {
    margin-top: 1.5rem;
    font-size: 0.85rem;
    opacity: 0.6;
  }

  .credits a {
    color: var(--primary);
    text-decoration: none;
    font-weight: 600;
    transition: var(--transition);
  }

  .credits a:hover {
    opacity: 1;
    text-decoration: underline;
  }

  @media (max-width: 992px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
    .footer-info {
      grid-column: span 2;
    }
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 4rem;
    }
    .footer-info {
      grid-column: span 1;
    }
  }
</style>
