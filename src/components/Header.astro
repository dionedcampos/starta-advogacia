---
import Logo from './Logo.astro';
---

<header class="header">
  <div class="container header-container">
    <a href="/" class="logo-link">
      <Logo width="180" height="60" light={false} />
    </a>
    <nav class="nav">
      <ul class="nav-list">
        <li><a href="#home">Início</a></li>
        <li><a href="#about">Sobre</a></li>
        <li><a href="#services">Áreas de Atuação</a></li>
        <li><a href="#testimonials">Depoimentos</a></li>
        <li class="mobile-cta-item"><a href="https://wa.me/559991764210?text=Olá! Gostaria de agendar uma consulta jurídica. Vi seu contato através do site." target="_blank" class="btn btn-primary">Consulta Grátis</a></li>
      </ul>
    </nav>
    <div class="header-actions">
      <a href="https://wa.me/559991764210?text=Olá! Gostaria de agendar uma consulta jurídica. Vi seu contato através do site." target="_blank" class="btn btn-primary btn-sm">Consulta Grátis</a>
    </div>
    <button class="mobile-menu-btn" aria-label="Alternar Menu" id="mobile-menu-toggle">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<script>
  // Mobile Menu Toggle
  const toggleBtn = document.getElementById('mobile-menu-toggle');
  const nav = document.querySelector('.nav');

  toggleBtn?.addEventListener('click', () => {
    nav?.classList.toggle('active');
    toggleBtn?.classList.toggle('active');
  });

  // Close menu when clicking a link
  const navLinks = document.querySelectorAll('.nav-list a');
  navLinks.forEach(link => {
    link.addEventListener('click', () => {
      nav?.classList.remove('active');
      toggleBtn?.classList.remove('active');
    });
  });

  // Scroll Spy
  const sections = document.querySelectorAll('section[id]');
  
  function highlightNav() {
    const scrollY = window.pageYOffset;
    
    sections.forEach(current => {
      const sectionHeight = (current as HTMLElement).offsetHeight;
      const sectionTop = (current as HTMLElement).offsetTop - 150;
      const sectionId = current.getAttribute('id');
      
      if (scrollY > sectionTop && scrollY <= sectionTop + sectionHeight) {
        document.querySelector(`.nav-list a[href*=${sectionId}]`)?.classList.add('active');
        document.querySelector(`.nav-list a[href*=${sectionId}]`)?.setAttribute('aria-current', 'page');
      } else {
        document.querySelector(`.nav-list a[href*=${sectionId}]`)?.classList.remove('active');
        document.querySelector(`.nav-list a[href*=${sectionId}]`)?.removeAttribute('aria-current');
      }
    });
  }

  window.addEventListener('scroll', highlightNav);
  window.addEventListener('load', highlightNav);
</script>

<style>
  .header {
    height: var(--header-height);
    background-color: rgba(255, 255, 255, 0.85); /* Fundo com opacidade para Glassmorphism */
    backdrop-filter: blur(12px); /* Efeito de desfoque premium */
    -webkit-backdrop-filter: blur(12px);
    position: sticky;
    top: 0;
    z-index: 1000;
    box-shadow: var(--shadow-sm);
    display: flex;
    justify-content: center; /* Center the container child */
    align-items: center;
    border-bottom: 1px solid rgba(0, 0, 0, 0.05); /* Subtle borderline for authority */
  }

  .header-container {
    width: 100%;
    display: flex;
    justify-content: flex-start; /* Aligned to left as requested */
    align-items: center;
    gap: 4rem; /* Space between logo and nav */
  }

  .logo-link {
    flex-shrink: 0;
  }

  .nav {
    flex-grow: 1;
  }

  .nav-list {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .nav-list a {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--text);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-family: var(--font-sans);
    position: relative;
    padding-bottom: 4px;
    transition: var(--transition);
  }

  .nav-list a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--primary);
    transition: var(--transition);
    transform-origin: left;
  }

  .nav-list a:hover {
    color: var(--primary);
  }

  .nav-list a:hover::after,
  .nav-list a.active::after {
    width: 100%;
  }

  .nav-list a.active {
    color: var(--primary);
  }

  .header-actions {
    flex-shrink: 0;
  }

  .btn-sm {
    padding: 0.7rem 1.4rem;
    font-size: 0.8rem;
    border-radius: 0; /* Sharp corners for professional look */
    border: 1px solid var(--primary);
  }

  .btn-sm:hover {
    background-color: transparent;
    color: var(--primary);
  }

  .mobile-menu-btn {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    flex-direction: column;
    gap: 6px;
    margin-left: auto;
    z-index: 1100;
  }

  .mobile-menu-btn span {
    display: block;
    width: 25px;
    height: 2px;
    background-color: var(--text);
    transition: var(--transition);
  }

  /* Mobile Button Animation */
  .mobile-menu-btn.active span:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }
  .mobile-menu-btn.active span:nth-child(2) {
    opacity: 0;
  }
  .mobile-menu-btn.active span:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

  @media (max-width: 1024px) {
    .header-actions {
      display: none;
    }

    .mobile-menu-btn {
      display: flex;
    }

    .nav {
      position: fixed;
      top: 0;
      right: -100%;
      width: 80%;
      max-width: 300px;
      height: 100vh;
      background-color: var(--bg);
      box-shadow: -5px 0 15px rgba(0,0,0,0.1);
      display: flex;
      flex-direction: column;
      padding: 3rem 1.5rem; /* Reduzido para caber mais itens */
      transition: var(--transition);
      z-index: 1050;
      overflow-y: auto; /* Permite scroll se o menu for longo */
    }

    .nav.active {
      right: 0;
    }

    .nav-list {
      flex-direction: column;
      align-items: center; /* Centralizado fica mais elegante no mobile */
      width: 100%;
      gap: 1rem; /* Gap menor pois usaremos padding nos links */
    }

    .nav-list li {
      width: 100%;
      text-align: center;
    }

    .nav-list a {
      display: block;
      width: 100%;
      padding: 1.5rem 0; /* Área de toque aumentada conforme solicitado */
      font-size: 1.1rem;
    }

    .header-container {
      justify-content: space-between;
      gap: 1rem; /* Gap reduzido para evitar overflow horizontal */
    }

    .mobile-cta-item {
      display: block;
      width: 100%;
      margin-top: 1rem;
    }
  }

  @media (min-width: 1025px) {
    .mobile-cta-item {
      display: none;
    }
  }
</style>
